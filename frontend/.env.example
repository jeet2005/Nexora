# Nexora Frontend - Environment Configurations

# Base URL for the Nexora FastAPI Backend API.
# In development, Vite proxy handles "/api" requests to http://localhost:8000.
# For production builds, set this to the absolute backend deployment URL (e.g., https://api.nexora.com/api).
VITE_API_BASE_URL=http://localhost:8000/api

# MongoDB persistence is configured in the backend environment file.
# Keep the frontend env aligned with the same API base URL and project settings.
VITE_API_BASE_URL=http://localhost:8000/api

# Firebase Authentication (required for user sign-in)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
