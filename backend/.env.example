# Nexora Backend - Environment Configurations

# Application Mode
# Options: development | production
APP_ENV=development
PORT=8000

# Base URLs
PUBLIC_API_URL=http://localhost:8000
PUBLIC_APP_URL=http://localhost:5173

# CORS Configuration
# Must be a JSON array of allowed origin strings.
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# Persistence Strategy
# Options: local | mongodb
# "local" saves uploaded datasets and metrics to the local "uploads/" folder as JSON/CSV.
PERSISTENCE_BACKEND=mongodb

# MongoDB Configuration (Required if PERSISTENCE_BACKEND=mongodb)
MONGODB_URI=mongodb+srv://mongodb_db_user:Password@cluster0.uef16i9.mongodb.net/nexora?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=nexora

# Firebase Authentication (Optional)
# Set these if you want to verify user login tokens.
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_FILE=firebase-service-account.json

# Local LLM Integration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_TIMEOUT=150
OLLAMA_MAX_TOKENS=256
